<!DOCTYPE html>
<html lang="mn">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Бишгүүр Сургалт</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: #080a10;
            color: #dddde8;
            font-family: 'Segoe UI', Arial, sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* SIDEBAR */
        #sidebar {
            width: 230px;
            min-height: 100vh;
            background: #0d0f18;
            border-right: 1px solid #1e2030;
            position: fixed;
            top: 0; left: 0; bottom: 0;
            z-index: 100;
            overflow-y: auto;
            padding-bottom: 20px;
        }
        #sidebar::-webkit-scrollbar { width: 3px; }
        #sidebar::-webkit-scrollbar-thumb { background: #1e2030; }

        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 1.2rem 1rem 1rem;
            border-bottom: 1px solid #1a1c28;
        }
        .sidebar-logo-icon {
            width: 38px; height: 38px;
            background: linear-gradient(135deg, #1e3460, #2a1a50);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 18px; flex-shrink: 0;
            border: 1px solid #2a3a60;
        }
        .sidebar-logo-mn { font-size: 13px; font-weight: 700; color: #e8e8f0; line-height: 1.2; }
        .sidebar-logo-en { font-size: 9px; color: #445; letter-spacing: .04em; margin-top: 2px; }

        .sidebar-section { padding: .8rem .7rem .3rem; }
        .sidebar-section-label {
            font-size: 9px; font-weight: 700;
            letter-spacing: .1em; text-transform: uppercase;
            color: #3a3d50;
            padding: 0 .4rem .5rem;
        }
<div style="padding:20px;background:red;color:white;font-size:20px;">
    ТОВЧНУУД ЭНД БАЙХ ЁСТОЙ
</div>
<button onclick="alert('Багийн танилцуулга')" 
        style="background:blue;color:white;padding:10px;width:100%;font-size:14px;border:none;cursor:pointer;margin-bottom:5px;">
    👥 Багийн танилцуулга
</button>
<button onclick="alert('Гэрчилгээ')" 
        style="background:gold;color:black;padding:10px;width:100%;font-size:14px;border:none;cursor:pointer;">
    📜 Оюуны өмчийн гэрчилгээ
</button>
        .nav-item {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 8px 10px;
            border-radius: 9px;
            cursor: pointer;
            font-size: 13px;
            color: #666;
            transition: background .15s, color .15s;
            text-decoration: none;
            margin-bottom: 2px;
            border: 1px solid transparent;
        }
        .nav-item:hover {
            background: #13151e;
            color: #b0b0c0;
            text-decoration: none;
        }
        .nav-item.active {
            background: linear-gradient(135deg, #0e1e34, #130e2a);
            color: #7ab8f5;
            border-color: #1e2a48;
        }
        .nav-icon {
            font-size: 14px;
            width: 20px;
            text-align: center;
            flex-shrink: 0;
        }

        .sidebar-divider {
            height: 1px;
            background: #14161e;
            margin: 1rem .8rem;
        }

        /* ═══ SPECIAL BUTTONS — ШИНЭЭР ЗАСВАРЛАСАН ═══ */
        .sb-special {
            padding: 0 12px;
            margin-top: 16px;
            display: block;
        }
        .sb-special-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            width: 100%;
            padding: 10px 12px;
            margin-bottom: 8px;
            border-radius: 10px;
            border: 1px solid #2a4070;
            background: linear-gradient(135deg, #121e36, #111528);
            color: #7ab8f5;
            font-size: 12px;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            text-align: left;
            transition: all .2s;
        }
        .sb-special-btn:hover {
            background: linear-gradient(135deg, #1a3060, #181d40);
            border-color: #4a90d9;
            color: #9ac8f8;
        }
        .sb-special-btn.gold {
            border-color: #503818;
            background: linear-gradient(135deg, #201408, #1a1206);
            color: #d8b840;
        }
        .sb-special-btn.gold:hover {
            background: linear-gradient(135deg, #2e1e0c, #22180a);
            border-color: #c09828;
            color: #f0d060;
        }

        /* MAIN CONTENT */
        #main-content {
            margin-left: 230px;
            min-height: 100vh;
            padding: 2rem;
        }

        .iframe-page {
            margin: -2rem;
            height: 100vh;
        }
        .iframe-page iframe {
            width: 100%;
            height: 100%;
            border: none;
            display: block;
        }

        /* MODAL OVERLAY */
        .lm-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.78);
            backdrop-filter: blur(7px);
            z-index: 9999;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }
        .lm-overlay.open { display: flex; }

        .lm-box {
            background: #0f111a;
            border: 1px solid #272a3e;
            border-radius: 18px;
            width: 100%;
            max-width: 640px;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 28px 70px rgba(0,0,0,.75);
        }
        .lm-box::-webkit-scrollbar { width: 4px; }
        .lm-box::-webkit-scrollbar-thumb { background: #252838; border-radius: 3px; }

        .lm-header {
            padding: 1.2rem 1.4rem 1rem;
            border-bottom: 1px solid #1a1c2c;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 14px;
            position: sticky; top: 0;
            background: #0f111a;
            z-index: 2;
        }
        .lm-badge {
            font-size: 9px; font-weight: 700; letter-spacing: .1em;
            text-transform: uppercase; padding: 3px 9px; border-radius: 5px;
            display: inline-block; margin-bottom: 5px;
        }
        .lm-badge.blue { background: #0a1828; color: #4a90d9; border: 1px solid #1a3050; }
        .lm-badge.gold { background: #1a1006; color: #c89828; border: 1px solid #302010; }
        .lm-title { font-size: 20px; font-weight: 700; line-height: 1.2; }
        .lm-close {
            width: 30px; height: 30px; border-radius: 8px;
            border: 1px solid #20222e; background: #13151e;
            color: #556; font-size: 14px; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .lm-close:hover { background: #1c1e2c; color: #e0e0e8; }
        .lm-body { padding: 1.2rem 1.4rem 1.5rem; }

        /* TEAM */
        .team-hero {
            display: flex; align-items: center; gap: 14px;
            padding: .85rem 1.1rem; margin-bottom: 1rem;
            background: linear-gradient(135deg, #080d1a, #0c1120);
            border-radius: 12px; border: 1px solid #151e36;
        }
        .team-hero-icon { font-size: 32px; flex-shrink: 0; }
        .team-hero-name { font-size: 15px; font-weight: 700; color: #7ab8f5; }
        .team-hero-sub  { font-size: 10px; color: #3a4060; margin-top: 2px; }
        .team-count-pill {
            display: inline-flex; align-items: center; gap: 4px;
            background: #0a1828; border: 1px solid #1a3050; border-radius: 20px;
            padding: 2px 9px; font-size: 11px; color: #4a90d9; margin-top: 5px;
        }

        .search-wrap { position: relative; margin-bottom: 10px; }
        .search-input {
            width: 100%; padding: 8px 12px 8px 34px;
            background: #080a10; border: 1px solid #1e2030;
            border-radius: 9px; color: #d8d8e8;
            font-size: 12px; font-family: inherit; outline: none;
        }
        .search-input:focus { border-color: #3a70b0; }
        .search-input::placeholder { color: #333; }
        .search-icon {
            position: absolute; left: 11px; top: 50%;
            transform: translateY(-50%); font-size: 12px; pointer-events: none;
        }

        .team-table-wrap {
            max-height: 360px; overflow-y: auto;
            border-radius: 10px; border: 1px solid #181a26;
        }
        .team-table-wrap::-webkit-scrollbar { width: 4px; }
        .team-table-wrap::-webkit-scrollbar-thumb { background: #1e2030; border-radius: 3px; }
        .team-table { width: 100%; border-collapse: collapse; }
        .team-table thead { position: sticky; top: 0; z-index: 1; background: #0c0e16; }
        .team-table th {
            padding: 8px 10px; font-size: 9px; font-weight: 700;
            letter-spacing: .08em; text-transform: uppercase;
            color: #3a3d50; text-align: left;
            border-bottom: 1px solid #181a26;
        }
        .team-table th:first-child { width: 30px; text-align: center; }
        .t-row { border-bottom: 1px solid #0e1018; }
        .t-row:last-child { border-bottom: none; }
        .t-row:hover { background: #111320; }
        .t-row td { padding: 8px 10px; font-size: 12px; vertical-align: middle; }
        .t-row td:first-child { text-align: center; }
        .t-num {
            font-size: 10px; color: #2a2c3a; font-family: monospace;
            background: #0c0e16; border-radius: 4px; padding: 2px 5px;
        }
        .t-avatar {
            width: 27px; height: 27px; border-radius: 50%;
            display: inline-flex; align-items: center; justify-content: center;
            font-size: 11px; font-weight: 700; flex-shrink: 0;
        }
        .t-name { font-weight: 600; color: #ccccd8; display: flex; align-items: center; gap: 7px; }
        .t-school { color: #38486a; font-size: 11px; }
        .t-subject {
            display: inline-block; padding: 2px 7px; border-radius: 4px;
            font-size: 10px; font-weight: 600;
        }
        .t-no-result { text-align: center; padding: 20px; color: #2a2c3a; font-size: 12px; }

        /* CERT */
        .cert-card {
            background: linear-gradient(160deg, #0e0c06, #14100a, #0e0c06);
            border: 2px solid #32240a;
            border-radius: 14px; padding: 1.4rem;
            position: relative; overflow: hidden;
        }
        .cert-card::before {
            content: '';
            position: absolute; top: -40px; right: -40px;
            width: 140px; height: 140px;
            background: radial-gradient(circle, rgba(200,152,40,.1), transparent 70%);
            pointer-events: none;
        }
        .cert-seal { position: absolute; top: 14px; right: 16px; font-size: 28px; opacity: .5; }
        .cert-tag {
            font-size: 9px; font-weight: 700; letter-spacing: .12em;
            color: #c09828; text-transform: uppercase; margin-bottom: 8px;
        }
        .cert-school-name {
            font-size: 22px; font-weight: 800; color: #f0c840;
            letter-spacing: .04em; margin-bottom: 3px;
        }
        .cert-school-full { font-size: 11px; color: #907020; margin-bottom: 10px; }
        .cert-divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, #302010, transparent);
            margin: 10px 0;
        }
        .cert-section-title {
            font-size: 10px; font-weight: 700; letter-spacing: .08em;
            color: #907020; text-transform: uppercase; margin-bottom: 8px;
        }
        .cert-initiator-box {
            background: linear-gradient(135deg, #1a1206, #120e04);
            border: 1px solid #4a3010;
            border-radius: 10px; padding: 12px 14px; margin-bottom: 10px;
        }
        .cert-init-title {
            font-size: 10px; font-weight: 700; letter-spacing: .08em;
            color: #d0a030; text-transform: uppercase;
            margin-bottom: 8px;
        }
        .cert-init-names { display: flex; flex-wrap: wrap; gap: 6px; }
        .cert-init-name {
            background: #201408; border: 1px solid #503818;
            color: #e8c060; font-size: 12px; font-weight: 600;
            padding: 4px 10px; border-radius: 6px;
        }
        .cert-member {
            display: flex; align-items: center; gap: 10px;
            padding: 7px 10px; margin-bottom: 5px;
            background: rgba(255,255,255,.025);
            border-radius: 7px; border-left: 2px solid #302010;
        }
        .cert-mnum { font-size: 10px; color: #504018; font-family: monospace; width: 18px; flex-shrink: 0; }
        .cert-mname { font-size: 12px; font-weight: 600; color: #d0be78; }
        .cert-mrole { font-size: 10px; color: #605838; margin-left: auto; white-space: nowrap; }
        .cert-footer {
            text-align: center; padding: 9px 12px; margin-top: 12px;
            background: #080602; border-radius: 7px;
            border: 1px solid #28180a;
            font-size: 10px; color: #504018;
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <nav id="sidebar">

        <div class="sidebar-logo">
            <div class="sidebar-logo-icon">🎵</div>
            <div>
                <div class="sidebar-logo-mn">Бишгүүр Сургалт</div>
                <div class="sidebar-logo-en">Recorder Learning System</div>
            </div>
        </div>

        <div class="sidebar-section">
            <div class="sidebar-section-label">Хичээлүүд</div>
            <a href="/Home/NotesLesson"
               class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "NotesLesson" ? "active" : "")">
                <span class="nav-icon">🎵</span> Нот сурах
            </a>
            <a href="/Home/FingeringLesson"
               class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "FingeringLesson" ? "active" : "")">
                <span class="nav-icon">👋</span> Хурууны байрлал
            </a>
            <a href="/Home/BreathingLesson"
               class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "BreathingLesson" ? "active" : "")">
                <span class="nav-icon">💨</span> Амьсгалын техник
            </a>
            <a href="/Home/PostureCoach"
               class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "PostureCoach" ? "active" : "")">
                <span class="nav-icon">🧍</span> Биеийн галбир
            </a>
        </div>

        <div class="sidebar-divider"></div>

        <div class="sidebar-section">
            <div class="sidebar-section-label">Хяналт</div>
            <a href="/Home/EngiinAyalguu"
               class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "EngiinAyalguu" ? "active" : "")">
                <span class="nav-icon">🔊</span> Дуу авианы хяналт
            </a>
            <a href="/Home/SongJourney"
               class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "SongJourney" ? "active" : "")">
                <span class="nav-icon">🎼</span> Энгийн аянууд
            </a>
        </div>

        <!-- ════ SPECIAL BUTTONS — ШУУД ХАРАГДДАГ БОЛОЛОО ════ -->
        <div class="sb-special">
            <button type="button" class="sb-special-btn" onclick="openTeamModal()">
                👥 Багийн танилцуулга
            </button>
            <button type="button" class="sb-special-btn gold" onclick="openCertModal()">
                📜 Оюуны өмчийн гэрчилгээ
            </button>
        </div>

    </nav>

    <!-- MAIN -->
    <main id="main-content">
        @RenderBody()
    </main>

    <!-- MODAL 1: БАГИЙН ТАНИЛЦУУЛГА -->
    <div class="lm-overlay" id="modal-team" onclick="if(event.target===this)closeTeamModal()">
        <div class="lm-box">
            <div class="lm-header">
                <div>
                    <div class="lm-badge blue">👥 БИШГҮҮР СУРГАЛТЫН СИСТЕМ</div>
                    <div class="lm-title" style="color:#7ab8f5">Багийн танилцуулга</div>
                </div>
                <button class="lm-close" onclick="closeTeamModal()">✕</button>
            </div>
            <div class="lm-body">
                <div class="team-hero">
                    <div class="team-hero-icon">🏫</div>
                    <div>
                        <div class="team-hero-name">БИШГҮҮР СУРГАЛТЫН СИСТЕМ</div>
                        <div class="team-hero-sub">Recorder Learning System · Багийн гишүүд</div>
                        <div class="team-count-pill">👩‍🏫 <span id="team-count-lbl">26</span> багш</div>
                    </div>
                </div>
                <div class="search-wrap">
                    <span class="search-icon">🔍</span>
                    <input class="search-input" id="team-search-inp" type="text"
                           placeholder="Нэр, сургууль, хичээлээр хайх..."
                           oninput="renderTeamTable(this.value)">
                </div>
                <div class="team-table-wrap">
                    <table class="team-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Багшийн нэр</th>
                                <th>Сургууль / байгууллага</th>
                                <th>Хичээл</th>
                            </tr>
                        </thead>
                        <tbody id="team-tbody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL 2: ОЮУНЫ ӨМЧИЙН ГЭРЧИЛГЭЭ -->
    <div class="lm-overlay" id="modal-cert" onclick="if(event.target===this)closeCertModal()">
        <div class="lm-box">
            <div class="lm-header">
                <div>
                    <div class="lm-badge gold">📜 ОЮУНЫ ӨМЧИЙН ГЭРЧИЛГЭЭ</div>
                    <div class="lm-title" style="color:#e8c040">Бишгүүр Сургалтын Систем</div>
                </div>
                <button class="lm-close" onclick="closeCertModal()">✕</button>
            </div>
            <div class="lm-body">
                <div class="cert-card">
                    <div class="cert-seal">🏅</div>
                    <div class="cert-tag">📌 Бүтээгч байгууллага</div>
                    <div class="cert-school-name">БАГА ТЭНГЭР</div>
                    <div class="cert-school-full">Бага Тэнгэр Ерөнхий Боловсролын Сургууль</div>

                    <div class="cert-divider"></div>

                    <div class="cert-section-title">💡 Анхлан санаачлагч</div>
                    <div class="cert-initiator-box">
                        <div class="cert-init-title">🏫 Багатэнгэр сургуулийн 9а анги</div>
                        <div class="cert-init-names">
                            <span class="cert-init-name">Хурцаа</span>
                            <span class="cert-init-name">Мядагмаа</span>
                            <span class="cert-init-name">Бүрэнтөгс</span>
                            <span class="cert-init-name">Баясгалан</span>
                        </div>
                    </div>

                    <div class="cert-divider"></div>

                    <div class="cert-section-title">💻 Мэдээлэл Технологийн Багш Гишүүд</div>
                    <div id="cert-members-list"></div>

                    <div class="cert-footer">
                        © 2025 БАГА ТЭНГЭР СУРГУУЛЬ · Бүх эрх хуулиар хамгаалагдсан
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        const TEAM = [
            { name:'Баасанжав Цэдмаа',            school:'Ирээдүй',                                           subject:'Англи хэл' },
            { name:'Махвал Золжаргал',             school:'Нийслэлийн нэгдүгээр сургууль',                    subject:'Газарзүйн багш' },
            { name:'Дамдинбазар Цэрэннамжил',      school:'Ивээлийн найзууд цэцэрлэг',                       subject:'Монгол хэлний багш' },
            { name:'Мөнхтөр Отгончимэг',           school:'—',                                                subject:'Сургуулийн өмнөх боловсролын багш' },
            { name:'Шура Болормаа',                school:'Ерөнхий Боловсролын Номын ёс сургууль',            subject:'Мэдээллийн технологи' },
            { name:'Г. Отгонтуяа',                 school:'62-р сургууль',                                    subject:'Дүрслэх урлаг' },
            { name:'Гансүх Батгэрэл',              school:'Номын ёс сургууль',                                subject:'Солонгос хэлний багш' },
            { name:'Б. Дайрий',                    school:'НЕБ-ын Ирээдүй сургууль',                         subject:'Нийгмийн ухааны багш' },
            { name:'Аюушжав Алтанцэцэг',           school:'НЕБ-ын Эрдмийн Өргөө сургууль',                  subject:'Бага ангийн багш' },
            { name:'Мөнхбаатарын Нандин-Эрдэнэ',  school:'НЕБ-ын 45-р сургууль',                            subject:'Дизайн технологи' },
            { name:'Дарамбазар Сугармаа',          school:'11-р сургууль',                                    subject:'Биологи' },
            { name:'Пүрвээ Үнэнбат',               school:'"Үр-Эрдэнэ" өдөр өнжүүлэх төв',                  subject:'Бага боловсролын багш' },
            { name:'Балжинням Баттуяа',            school:'Нийслэлийн "Ирээдүй" сургууль',                   subject:'Бага ангийн багш' },
            { name:'Амар Цэндбаатар',              school:'Цэлмэг Дижитал интернэйшнл сургууль',             subject:'График дизайн' },
            { name:'Баатар Армунаа',               school:'Шинэ эхлэл олон улсын хөтөлбөрийн сургууль',      subject:'Математикийн багш' },
            { name:'Дүвчиндорж Оюунчимэг',         school:'—',                                                subject:'Англи хэл' },
            { name:'Отгоны Мөнхцэцэг',             school:'НЕБ-ын 63 дугаар сургууль',                       subject:'Тусгай хэрэгцээт боловсрол' },
            { name:'Батнямын Даваажаргал',          school:'НЕБ-ийн "Хөгжил" сургууль',                      subject:'Англи хэлний багш' },
            { name:'Дэмбэрэлбаясгалан Дэлгэрмаа', school:'25-р сургууль',                                    subject:'Түүх, тусгай хэрэгцээт боловсрол' },
            { name:'Ганмягмар Дөлгөөнсувд',        school:'ШУТИС',                                            subject:'МХС-ний инжнерчлэл' },
            { name:'Дэлгэрийн Амармэнд',            school:'52-р сургууль',                                   subject:'МТ багш' },
            { name:'Аръяа Болортуяа',              school:'31-р сургууль',                                    subject:'МТ багш' },
            { name:'Б. Долгорсүрэн',               school:'Ирээдүй',                                          subject:'Бага ангийн багш' },
            { name:'Рагчаагийн Бигэрмаа',          school:'ШУТИС, Гадаад хэлний сургууль',                   subject:'Монгол хэл, уран зохиол' },
            { name:'Намшир Ариунзаяа',             school:'11-р сургууль',                                    subject:'Дүрслэх урлаг, дизайн технологи' },
            { name:'Наранцэцэг Шинэбаяр',          school:'16-р сургууль',                                    subject:'Дизайн технологи' },
        ];

        const CERT = [
            { name:'Шура Болормаа',                role:'МТ багш — Номын ёс сургууль' },
            { name:'Мөнхбаатарын Нандин-Эрдэнэ',  role:'Дизайн технологи — 45-р сургууль' },
            { name:'Амар Цэндбаатар',              role:'График дизайн — Цэлмэг Дижитал' },
            { name:'Ганмягмар Дөлгөөнсувд',        role:'МХС инжнер — ШУТИС' },
            { name:'Дэлгэрийн Амармэнд',            role:'МТ багш — 52-р сургууль' },
            { name:'Аръяа Болортуяа',              role:'МТ багш — 31-р сургууль' },
            { name:'Намшир Ариунзаяа',             role:'Дүрслэх урлаг дизайн — 11-р сургууль' },
            { name:'Наранцэцэг Шинэбаяр',          role:'Дизайн технологи — 16-р сургууль' },
        ];

        const AV = ['#4a90d9','#3dbe6a','#9a70d9','#d060a0','#d0a030','#e07050','#3dc8b0','#5090e0','#c050c0','#50c080'];

        function subjectStyle(s) {
            if (s.includes('МТ') || s.includes('Мэдээл') || s.includes('инжнер'))
                return 'background:#081424;color:#4890d8;border:1px solid #102040';
            if (s.includes('Дизайн') || s.includes('График') || s.includes('Дүрслэх'))
                return 'background:#14082a;color:#9060d0;border:1px solid #201040';
            if (s.includes('Англи'))
                return 'background:#081a1a;color:#30b0a0;border:1px solid #0e2828';
            if (s.includes('Монгол') || s.includes('уран'))
                return 'background:#081a10;color:#30a860;border:1px solid #0e2818';
            if (s.includes('Биологи'))
                return 'background:#081808;color:#40a840;border:1px solid #0e2810';
            if (s.includes('Бага') || s.includes('өмнөх'))
                return 'background:#1a1808;color:#c0a020;border:1px solid #282408';
            if (s.includes('Математик'))
                return 'background:#081428;color:#4080d0;border:1px solid #102038';
            if (s.includes('Түүх') || s.includes('Нийгмийн'))
                return 'background:#181408;color:#b08020;border:1px solid #281e08';
            if (s.includes('Тусгай'))
                return 'background:#201008;color:#d06820;border:1px solid #301808';
            if (s.includes('Солонгос'))
                return 'background:#180818;color:#d060b0;border:1px solid #280828';
            if (s.includes('Газар'))
                return 'background:#081808;color:#40a840;border:1px solid #0e2810';
            return 'background:#101216;color:#607080;border:1px solid #181e24';
        }

        function renderTeamTable(q) {
            q = (q || '').toLowerCase().trim();
            const list = q
                ? TEAM.filter(m =>
                    m.name.toLowerCase().includes(q) ||
                    m.school.toLowerCase().includes(q) ||
                    m.subject.toLowerCase().includes(q))
                : TEAM;
            document.getElementById('team-count-lbl').textContent = list.length;
            const tbody = document.getElementById('team-tbody');
            tbody.innerHTML = '';
            if (!list.length) {
                tbody.innerHTML = '<tr><td colspan="4" class="t-no-result">🔍 Тохирох багш олдсонгүй</td></tr>';
                return;
            }
            list.forEach(m => {
                const ri = TEAM.indexOf(m);
                const col = AV[ri % AV.length];
                const init = m.name.replace(/^[А-ЯӨҮа-яөүA-Z]\.\s*/, '').charAt(0).toUpperCase();
                const tr = document.createElement('tr');
                tr.className = 't-row';
                tr.innerHTML = `
                    <td><span class="t-num">${String(ri + 1).padStart(2, '0')}</span></td>
                    <td><div class="t-name">
                        <span class="t-avatar" style="background:${col}1e;border:1.5px solid ${col}44;color:${col}">${init}</span>
                        ${m.name}
                    </div></td>
                    <td><span class="t-school">${m.school}</span></td>
                    <td><span class="t-subject" style="${subjectStyle(m.subject)}">${m.subject}</span></td>`;
                tbody.appendChild(tr);
            });
        }

        function renderCertMembers() {
            const el = document.getElementById('cert-members-list');
            el.innerHTML = '';
            CERT.forEach((m, i) => {
                const d = document.createElement('div');
                d.className = 'cert-member';
                d.innerHTML = `
                    <span class="cert-mnum">${String(i + 1).padStart(2, '0')}</span>
                    <span class="cert-mname">${m.name}</span>
                    <span class="cert-mrole">${m.role}</span>`;
                el.appendChild(d);
            });
        }

        function openTeamModal() {
            renderTeamTable('');
            document.getElementById('team-search-inp').value = '';
            document.getElementById('modal-team').classList.add('open');
            document.body.style.overflow = 'hidden';
            setTimeout(() => document.getElementById('team-search-inp').focus(), 280);
        }
        function closeTeamModal() {
            document.getElementById('modal-team').classList.remove('open');
            document.body.style.overflow = '';
        }
        function openCertModal() {
            renderCertMembers();
            document.getElementById('modal-cert').classList.add('open');
            document.body.style.overflow = 'hidden';
        }
        function closeCertModal() {
            document.getElementById('modal-cert').classList.remove('open');
            document.body.style.overflow = '';
        }
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') { closeTeamModal(); closeCertModal(); }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
