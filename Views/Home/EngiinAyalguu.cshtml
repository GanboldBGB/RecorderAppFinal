@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="mn">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Энгийн Аялгуу — Бишгүүр Сургалт</title>
    <style>
        :root {
            --bg:  #0c0e14;
            --s1:  #13151d;
            --s2:  #191c28;
            --s3:  #1f2235;
            --bd:  #252840;
            --ac:  #5b9cf6;
            --tx:  #eef0f8;
            --tx2: #9298b8;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body, html {
            background: var(--bg);
            color: var(--tx);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            height: 100vh;
            overflow: hidden;
        }
        .app-wrapper { display: flex; height: 100vh; }

        /* ── Sidebar ── */
        .sidebar {
            width: 260px;
            background: var(--s1);
            border-right: 1px solid var(--bd);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            flex-shrink: 0;
        }
        .sidebar-header {
            padding: 18px 15px;
            border-bottom: 1px solid var(--bd);
        }
        .back-btn {
            display: flex; align-items: center; gap: 8px;
            padding: 8px 12px;
            background: var(--s2);
            border: 1px solid var(--bd);
            color: var(--tx2);
            border-radius: 8px;
            cursor: pointer;
            font-size: 13px;
            text-decoration: none;
            margin-bottom: 14px;
            transition: 0.2s;
            width: fit-content;
        }
        .back-btn:hover { color: var(--tx); background: var(--s3); }
        .sidebar-title   { font-size: 16px; font-weight: 700; color: var(--tx); }
        .sidebar-sub     { font-size: 12px; color: var(--tx2); margin-top: 3px; }

        .songs-list { flex: 1; overflow-y: auto; padding: 10px; }

        .song-item {
            padding: 12px 15px;
            border-radius: 10px;
            cursor: pointer;
            transition: 0.2s;
            margin-bottom: 6px;
            border: 1px solid transparent;
        }
        .song-item:hover { background: var(--s2); }
        .song-item.active { background: var(--s3); border-color: var(--bd); }
        .song-item.active .song-name { color: var(--ac); }
        .song-name { font-size: 14px; font-weight: 600; color: var(--tx); margin-bottom: 5px; }
        .song-meta { font-size: 12px; color: var(--tx2); display: flex; gap: 8px; align-items: center; }

        .diff-badge { padding: 2px 8px; border-radius: 20px; font-size: 11px; font-weight: 600; }
        .diff-easy   { background: #1a3a1a; color: #4caf74; }
        .diff-medium { background: #3a2a1a; color: #f0a040; }
        .diff-hard   { background: #3a1a1a; color: #e05050; }

        /* ── Main Content ── */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            padding: 20px;
            gap: 15px;
        }

        /* Song Header */
        .song-header {
            background: var(--s1);
            border: 1px solid var(--bd);
            border-radius: 14px;
            padding: 18px 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-shrink: 0;
        }
        .song-header-left h2 { font-size: 20px; color: var(--tx); }
        .song-header-left p  { color: var(--tx2); font-size: 13px; margin-top: 4px; }

        .controls { display: flex; align-items: center; gap: 10px; }
        .ctrl-btn {
            width: 44px; height: 44px;
            border-radius: 50%;
            border: none;
            cursor: pointer;
            font-size: 18px;
            display: flex; align-items: center; justify-content: center;
            transition: 0.2s;
        }
        .ctrl-btn.play  { background: var(--ac); color: #fff; }
        .ctrl-btn.play:hover  { background: #4a8ce0; transform: scale(1.05); }
        .ctrl-btn.reset { background: var(--s2); color: var(--tx2); border: 1px solid var(--bd); }
        .ctrl-btn.reset:hover { background: var(--s3); color: var(--tx); }

        .bpm-control {
            display: flex; align-items: center; gap: 8px;
            background: var(--s2);
            border: 1px solid var(--bd);
            border-radius: 8px;
            padding: 6px 12px;
        }
        .bpm-control label { font-size: 12px; color: var(--tx2); }
        .bpm-control input[type=range] { width: 80px; accent-color: var(--ac); }
        .bpm-val { font-size: 13px; color: var(--ac); font-weight: bold; min-width: 35px; }

        /* Notes Row */
        .notes-container {
            background: var(--s1);
            border: 1px solid var(--bd);
            border-radius: 14px;
            padding: 18px 20px 12px;
            flex-shrink: 0;
        }
        .notes-row {
            display: flex;
            gap: 8px;
            align-items: flex-end;
            min-height: 75px;
            overflow-x: auto;
            padding-bottom: 8px;
        }
        .note-block {
            min-width: 52px;
            height: 60px;
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: transform 0.15s, box-shadow 0.15s;
            border: 2px solid transparent;
            flex-shrink: 0;
        }
        .note-block:hover  { transform: translateY(-3px); }
        .note-block.active {
            transform: translateY(-8px) scale(1.15);
            border-color: rgba(255,255,255,0.8);
            box-shadow: 0 10px 28px rgba(0,0,0,0.6);
        }
        .note-block.played { opacity: 0.35; }
        .note-sym { font-size: 18px; font-weight: bold; color: #fff; }
        .note-idx { font-size: 10px; color: rgba(255,255,255,0.6); margin-top: 2px; }

        /* Нотын өнгө */
        .note-C { background: linear-gradient(135deg,#c0392b,#e74c3c); }
        .note-D { background: linear-gradient(135deg,#d35400,#e67e22); }
        .note-E { background: linear-gradient(135deg,#b7950b,#f1c40f); }
        .note-F { background: linear-gradient(135deg,#1e8449,#27ae60); }
        .note-G { background: linear-gradient(135deg,#1a5276,#2980b9); }
        .note-A { background: linear-gradient(135deg,#4a235a,#8e44ad); }
        .note-B { background: linear-gradient(135deg,#6e2c00,#ba4a00); }

        /* Progress */
        .progress-bar-wrap { background: var(--s2); border-radius: 4px; height: 5px; overflow: hidden; margin-top: 10px; }
        .progress-bar { height: 100%; background: var(--ac); border-radius: 4px; transition: width 0.3s; }
        .progress-text { font-size: 11px; color: var(--tx2); margin-top: 5px; }

        /* Bottom Panel */
        .bottom-panel {
            display: grid;
            grid-template-columns: 180px 1fr;
            gap: 15px;
            flex: 1;
            min-height: 0;
        }

        /* Fingering Card */
        .fingering-card {
            background: var(--s1);
            border: 1px solid var(--bd);
            border-radius: 14px;
            padding: 18px 15px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            overflow: hidden;
        }
        .cur-note-label { font-size: 11px; color: var(--tx2); letter-spacing: 1px; }
        .cur-note-name  { font-size: 48px; font-weight: 900; line-height: 1; }
        .cur-note-mn    { font-size: 14px; color: var(--tx2); margin-top: -6px; }
        .hole-hint { font-size: 11px; color: var(--tx2); text-align: center; line-height: 1.6; margin-top: 5px; }

        /* Info Card */
        .info-card {
            background: var(--s1);
            border: 1px solid var(--bd);
            border-radius: 14px;
            padding: 22px 25px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 18px;
        }
        .info-section-title {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--tx2);
            margin-bottom: 10px;
        }
        .note-legend {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 8px;
        }
        .legend-item {
            border-radius: 10px;
            padding: 10px 6px;
            text-align: center;
            cursor: pointer;
            transition: 0.2s;
        }
        .legend-item:hover { transform: scale(1.08); }
        .legend-sym { font-size: 18px; font-weight: bold; color: #fff; }
        .legend-mn  { font-size: 11px; color: rgba(255,255,255,0.8); margin-top: 3px; }

        .tip-box {
            background: var(--s2);
            border: 1px solid var(--bd);
            border-radius: 10px;
            padding: 14px 16px;
            font-size: 14px;
            color: var(--tx2);
            line-height: 1.7;
        }
        .tip-box strong { color: var(--tx); }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--bd); border-radius: 3px; }
    </style>
</head>
<body>
<div class="app-wrapper">

    <!-- ══════════════════════════════════
         SIDEBAR
    ══════════════════════════════════ -->
    <div class="sidebar">
        <div class="sidebar-header">
            <a href="/" class="back-btn">← Буцах</a>
            <div class="sidebar-title">🎸 Энгийн Аялгуу</div>
            <div class="sidebar-sub">Монгол алдартай дуунууд</div>
        </div>
        <div class="songs-list" id="songs-list">
            <!-- JS-ээр дүүргэнэ -->
        </div>
    </div>

    <!-- ══════════════════════════════════
         ҮНДСЭН АГУУЛГА
    ══════════════════════════════════ -->
    <div class="main-content">

        <!-- Song Header -->
        <div class="song-header">
            <div class="song-header-left">
                <h2 id="hdr-title">Аялгуу сонгоно уу</h2>
                <p id="hdr-meta">Зүүн гар талаас дуугаа сонгоод эхлэнэ үү</p>
            </div>
            <div class="controls">
                <div class="bpm-control">
                    <label>BPM</label>
                    <input type="range" id="bpm-slider" min="40" max="160" value="80"
                           oninput="updateBPM(this.value)">
                    <span class="bpm-val" id="bpm-val">80</span>
                </div>
                <button class="ctrl-btn reset" onclick="resetSong()" title="Эхнээс эхлэх">↺</button>
                <button class="ctrl-btn play"  id="btn-play" onclick="togglePlay()">▶</button>
            </div>
        </div>

        <!-- Notes Row -->
        <div class="notes-container">
            <div class="notes-row" id="notes-row">
                <div style="color:var(--tx2);font-size:14px;margin:auto;">
                    ← Аялгуу сонгоно уу
                </div>
            </div>
            <div class="progress-bar-wrap">
                <div class="progress-bar" id="progress-bar" style="width:0%"></div>
            </div>
            <div class="progress-text" id="progress-text">0 / 0</div>
        </div>

        <!-- Bottom Panel -->
        <div class="bottom-panel">

            <!-- Хуруу тавилт -->
            <div class="fingering-card">
                <div class="cur-note-label">ОДООГИЙН НОТ</div>
                <div class="cur-note-name" id="cur-note-name" style="color:#5b9cf6">—</div>
                <div class="cur-note-mn"   id="cur-note-mn"  style="color:#5b9cf6"></div>

                <!-- Бишгүүрийн зураг (SVG) -->
                <svg id="recorder-svg" width="68" height="230" viewBox="0 0 68 230"
                     style="transition: filter 0.3s;">
                    <!-- Бие -->
                    <rect x="24" y="8" width="20" height="215" fill="#b8904a" rx="6"/>
                    <!-- Амсар -->
                    <rect x="27" y="0" width="14" height="16" fill="#8a6030" rx="3"/>
                    <!-- Эрхий нүх (ар тал) -->
                    <circle id="hole-thumb" cx="14" cy="42" r="7"
                            fill="#1a1008" stroke="#8a6030" stroke-width="1.5"/>
                    <line x1="21" y1="42" x2="24" y2="42" stroke="#8a6030" stroke-width="1.5"/>
                    <!-- Урд нүхнүүд -->
                    <circle id="hole-1" cx="34" cy="68"  r="7" fill="#1a1008" stroke="#8a6030" stroke-width="1.5"/>
                    <circle id="hole-2" cx="34" cy="93"  r="7" fill="#1a1008" stroke="#8a6030" stroke-width="1.5"/>
                    <circle id="hole-3" cx="34" cy="118" r="7" fill="#1a1008" stroke="#8a6030" stroke-width="1.5"/>
                    <circle id="hole-4" cx="34" cy="143" r="6" fill="#1a1008" stroke="#8a6030" stroke-width="1.5"/>
                    <circle id="hole-5" cx="34" cy="161" r="6" fill="#1a1008" stroke="#8a6030" stroke-width="1.5"/>
                    <circle id="hole-6" cx="34" cy="179" r="6" fill="#1a1008" stroke="#8a6030" stroke-width="1.5"/>
                    <!-- Ёроол -->
                    <ellipse cx="34" cy="222" rx="13" ry="5" fill="#9a7030"/>
                </svg>

                <div class="hole-hint">⚫ = Нүх хаах<br>⚪ = Нүх нээх</div>
            </div>

            <!-- Мэдээлэл -->
            <div class="info-card">
                <div>
                    <div class="info-section-title">Нотын заавар — нот дарж хуруу тавилтыг харна уу</div>
                    <div class="note-legend" id="note-legend"></div>
                </div>
                <div>
                    <div class="info-section-title">💡 Зөвлөгөө</div>
                    <div class="tip-box" id="tip-text">
                        Аялгуу сонгоод <strong>▶</strong> товч дарж эхлэн үү.<br>
                        Нот тус бүр дээр дарахад хуруу тавих байрлалыг харах боломжтой.
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
/* ═══════════════════════════════
   НОТ ТОХИРГОО
═══════════════════════════════ */
const NOTE_COLORS = {
    C:'#e74c3c', D:'#e67e22', E:'#f1c40f',
    F:'#27ae60', G:'#2980b9', A:'#8e44ad', B:'#ba4a00'
};
const NOTE_MN = {
    C:'До', D:'Ре', E:'Ми', F:'Фа', G:'Соль', A:'Ля', B:'Си'
};

// [эрхий, 1-р, 2-р, 3-р, 4-р, 5-р, 6-р нүх]
// true = хаах, false = нээх
const FINGERING = {
    C: [true,  true,  true,  true,  true,  true,  true ],
    D: [true,  true,  true,  true,  true,  true,  false],
    E: [true,  true,  true,  true,  true,  false, false],
    F: [true,  true,  true,  true,  false, true,  false],
    G: [true,  true,  true,  true,  false, false, false],
    A: [true,  true,  true,  false, false, false, false],
    B: [true,  true,  false, false, false, false, false],
};

/* ═══════════════════════════════
   МОНГОЛ АЯЛГУУНУУДЫН ӨГӨГДӨЛ
═══════════════════════════════ */
const SONGS = [
    {
        id: 1,
        title: "Загалмайт найз",
        artist: "Монгол ардын дуу",
        difficulty: "easy",
        bpm: 80,
        desc: "Монголын эртний алдарт ардын дуу. Хялбар хэмнэлтэй, эхлэгчдэд тохиромжтой.",
        tip: "G нотыг тогтвортой болтол давта. Дараа нь A болон E нэмнэ.",
        notes: ["G","G","A","G","E","D","E","G",
                "G","G","A","G","D","C","D","E",
                "G","E","G","A","G","E","D","C"]
    },
    {
        id: 2,
        title: "Говийн замд",
        artist: "Монгол уртын дуу",
        difficulty: "easy",
        bpm: 65,
        desc: "Говийн талыг дуулсан уртын дууны аялгуу. Удаан, тайван хэмнэл.",
        tip: "Амьсгалаа алдалгүй тасралтгүй үлээ. Нот бүрийг урт дуугарга.",
        notes: ["G","G","G","A","G","E","D",
                "E","E","G","A","G","G","G",
                "A","G","E","D","C","D","E","G"]
    },
    {
        id: 3,
        title: "Эхийн сэтгэл",
        artist: "Монгол ардын дуу",
        difficulty: "medium",
        bpm: 75,
        desc: "Ээжийн хайрыг өгүүлсэн зөөлөн уянгатай аялгуу.",
        tip: "C нотоос эхлэхдээ бүх нүхийг нягт хаана. Хүчилсэн хэрэггүй, зөөлөн үлээ.",
        notes: ["C","E","G","A","G","E","D","C",
                "D","E","G","A","G","G","E","G",
                "A","G","E","D","C","D","E","C"]
    },
    {
        id: 4,
        title: "Хурдан морь",
        artist: "Монгол ардын дуу",
        difficulty: "medium",
        bpm: 105,
        desc: "Монгол морины хурдыг дуулсан жигтэй хөгжилтэй аялгуу.",
        tip: "Эхлээд 60 BPM-ээр дасгалла. Гар хурдасхийрэй болсны дараа BPM нэмэгдүүл.",
        notes: ["G","A","G","E","D","E","G","A",
                "G","G","E","D","C","D","E","G",
                "A","G","E","G","A","G","D","C"]
    },
    {
        id: 5,
        title: "Нутгийн уул",
        artist: "Монгол ардын дуу",
        difficulty: "easy",
        bpm: 72,
        desc: "Эх нутгийн уулыг магтсан тайван уянгатай аялгуу.",
        tip: "Нот бүрийн уртыг тэгш байлга. Яарахгүй, тайван хэмнэлтэй тогло.",
        notes: ["E","E","G","G","A","G","E","D",
                "C","D","E","G","G","E","G","A",
                "G","E","D","E","C"]
    },
    {
        id: 6,
        title: "Жаргалант нутаг",
        artist: "Монгол ардын дуу",
        difficulty: "easy",
        bpm: 78,
        desc: "Жаргалант нутгийн дуулал. Дурлалтай, хөгжилтэй аялгуу.",
        tip: "D нотын хурууны байрлалыг сайн дасгалла. Нот хооронд тасрахгүй байх хэрэгтэй.",
        notes: ["D","E","G","G","A","G","E","D",
                "E","G","A","A","G","E","G","G",
                "E","D","E","G","A","G","E","D"]
    },
    {
        id: 7,
        title: "Монгол нутаг",
        artist: "Алдартай монгол дуу",
        difficulty: "hard",
        bpm: 90,
        desc: "Монгол нутгийн уудам тал хээрийг дуулсан баялаг аялгуу.",
        tip: "Нот дарааллыг цээжилж ав. Хурааж, нээх хурууны хөдөлгөөнийг тогворжуул.",
        notes: ["G","A","B","A","G","E","D","E",
                "G","A","G","E","D","C","D","E",
                "G","A","B","B","A","G","E","G",
                "A","G","E","D","C"]
    },
    {
        id: 8,
        title: "Алтайн оргил",
        artist: "Алтай аялгуу",
        difficulty: "hard",
        bpm: 85,
        desc: "Алтайн уулын цэнгэлийг дуулсан өндөр аялгуу. Бүх нот хамарна.",
        tip: "B нот хамгийн хэцүү — зөвхөн эрхий болон 1-р нүхийг хаана, бусдыг нээ.",
        notes: ["C","D","E","G","A","B","A","G",
                "E","D","C","D","E","G","A","B",
                "A","G","E","G","A","B","A","G",
                "E","D","C"]
    }
];

/* ═══════════════════════════════
   АЯЛГУУ ЖАГСААЛТ ҮҮСГЭХ
═══════════════════════════════ */
function buildSongList() {
    const c = document.getElementById('songs-list');
    const dLabel = { easy:'Хялбар', medium:'Дунд', hard:'Хэцүү' };
    const dClass = { easy:'diff-easy', medium:'diff-medium', hard:'diff-hard' };

    c.innerHTML = SONGS.map(s => `
        <div class="song-item" id="si-${s.id}" onclick="selectSong(${s.id})">
            <div class="song-name">${s.title}</div>
            <div class="song-meta">
                <span>${s.artist}</span>
                <span class="diff-badge ${dClass[s.difficulty]}">${dLabel[s.difficulty]}</span>
            </div>
        </div>
    `).join('');
}

/* ═══════════════════════════════
   НОТ ЛЕГЕНД ҮҮСГЭХ
═══════════════════════════════ */
function buildLegend() {
    const c = document.getElementById('note-legend');
    c.innerHTML = Object.keys(NOTE_COLORS).map(n => `
        <div class="legend-item note-${n}" onclick="showFingering('${n}')"
             title="${n} нотын хуруу тавилт харах">
            <div class="legend-sym">${n}</div>
            <div class="legend-mn">${NOTE_MN[n]}</div>
        </div>
    `).join('');
}

/* ═══════════════════════════════
   ХУРУУ ТАВИЛТ ХАРУУЛАХ
═══════════════════════════════ */
function showFingering(note) {
    if (!note || !FINGERING[note]) return;
    const f     = FINGERING[note];
    const color = NOTE_COLORS[note];
    const closed = '#1a0a02';
    const open   = '#f0d080';

    document.getElementById('cur-note-name').textContent = note;
    document.getElementById('cur-note-name').style.color = color;
    document.getElementById('cur-note-mn').textContent   = NOTE_MN[note];
    document.getElementById('cur-note-mn').style.color   = color;

    const holes = ['hole-thumb','hole-1','hole-2','hole-3','hole-4','hole-5','hole-6'];
    holes.forEach((id, i) => {
        const el = document.getElementById(id);
        if (el) {
            el.setAttribute('fill',   f[i] ? closed : open);
            el.setAttribute('stroke', f[i] ? '#8a6030' : color);
        }
    });

    document.getElementById('recorder-svg').style.filter =
        `drop-shadow(0 0 12px ${color}88)`;
}

/* ═══════════════════════════════
   АЯЛГУУ СОНГОХ
═══════════════════════════════ */
let currentSong = null;
let currentIdx  = 0;
let isPlaying   = false;
let playTimer   = null;
let currentBPM  = 80;

function selectSong(id) {
    resetSong();
    currentSong = SONGS.find(s => s.id === id);
    if (!currentSong) return;

    document.querySelectorAll('.song-item').forEach(el => el.classList.remove('active'));
    document.getElementById(`si-${id}`).classList.add('active');

    document.getElementById('hdr-title').textContent = currentSong.title;
    document.getElementById('hdr-meta').textContent  =
        `${currentSong.artist} · ${currentSong.notes.length} нот`;

    currentBPM = currentSong.bpm;
    document.getElementById('bpm-slider').value  = currentBPM;
    document.getElementById('bpm-val').textContent = currentBPM;

    buildNotesRow();

    document.getElementById('tip-text').innerHTML =
        `<strong>${currentSong.desc}</strong><br><br>💡 ${currentSong.tip}`;

    showFingering(currentSong.notes[0]);
    highlightNote(0);
    updateProgress(0);
}

/* ═══════════════════════════════
   НОТЫН МӨР ҮҮСГЭХ
═══════════════════════════════ */
function buildNotesRow() {
    if (!currentSong) return;
    document.getElementById('notes-row').innerHTML =
        currentSong.notes.map((n, i) => `
            <div class="note-block note-${n}" id="nb-${i}" onclick="jumpToNote(${i})">
                <div class="note-sym">${n}</div>
                <div class="note-idx">${i + 1}</div>
            </div>
        `).join('');
}

function highlightNote(idx) {
    document.querySelectorAll('.note-block').forEach((el, i) => {
        el.classList.remove('active', 'played');
        if (i < idx)  el.classList.add('played');
        if (i === idx) el.classList.add('active');
    });
    const el = document.getElementById(`nb-${idx}`);
    if (el) el.scrollIntoView({ behavior:'smooth', inline:'center', block:'nearest' });
}

function jumpToNote(idx) {
    if (!currentSong) return;
    currentIdx = idx;
    highlightNote(idx);
    showFingering(currentSong.notes[idx]);
    updateProgress(idx);
}

function updateProgress(idx) {
    if (!currentSong) return;
    const pct = Math.round((idx / currentSong.notes.length) * 100);
    document.getElementById('progress-bar').style.width = pct + '%';
    document.getElementById('progress-text').textContent =
        `${idx} / ${currentSong.notes.length} нот`;
}

/* ═══════════════════════════════
   ТОГЛОХ УДИРДЛАГА
═══════════════════════════════ */
function togglePlay() {
    if (!currentSong) return;
    isPlaying ? pauseSong() : playSong();
}

function playSong() {
    isPlaying = true;
    document.getElementById('btn-play').textContent = '⏸';
    scheduleNext();
}

function pauseSong() {
    isPlaying = false;
    document.getElementById('btn-play').textContent = '▶';
    clearTimeout(playTimer);
}

function resetSong() {
    pauseSong();
    currentIdx = 0;
    document.querySelectorAll('.note-block').forEach(el =>
        el.classList.remove('active', 'played'));
    if (currentSong) {
        highlightNote(0);
        showFingering(currentSong.notes[0]);
        updateProgress(0);
    }
}

function scheduleNext() {
    if (!isPlaying || !currentSong) return;

    highlightNote(currentIdx);
    showFingering(currentSong.notes[currentIdx]);
    updateProgress(currentIdx);
    currentIdx++;

    if (currentIdx >= currentSong.notes.length) {
        setTimeout(() => {
            pauseSong();
            currentIdx = 0;
            const nameEl = document.getElementById('cur-note-name');
            nameEl.textContent = '✓';
            nameEl.style.color = '#27ae60';
            document.getElementById('cur-note-mn').textContent = 'Дууслаа!';
            document.getElementById('cur-note-mn').style.color = '#27ae60';
            document.getElementById('recorder-svg').style.filter =
                'drop-shadow(0 0 18px #27ae60)';
        }, (60 / currentBPM) * 1000);
        return;
    }

    playTimer = setTimeout(scheduleNext, (60 / currentBPM) * 1000);
}

function updateBPM(val) {
    currentBPM = parseInt(val);
    document.getElementById('bpm-val').textContent = val;
}

/* ═══════════════════════════════
   ЭХЛҮҮЛЭХ
═══════════════════════════════ */
buildSongList();
buildLegend();
showFingering('G');
</script>
</body>
</html>