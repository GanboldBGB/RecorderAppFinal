                </div>
            </div>
        </div>
    </div>
</div>

<script>
    /* ══════════════════════════════════════
       БАГИЙН ӨГӨГДӨЛ — 26 багш
    ══════════════════════════════════════ */
    const TEAM = [
        { name:'Баасанжав Цэдмаа',              school:'Ирээдүй',                                              subject:'Англи хэл' },
        { name:'Махвал Золжаргал',              school:'Нийслэлийн нэгдүгээр сургууль',                       subject:'Газарзүйн багш' },
        { name:'Дамдинбазар Цэрэннамжил',       school:'Ивээлийн найзууд цэцэрлэг',                           subject:'Монгол хэлний багш' },
        { name:'Мөнхтөр Отгончимэг',            school:'—',                                                    subject:'Сургуулийн өмнөх боловсролын багш' },
        { name:'Шура Болормаа',                 school:'Ерөнхий Боловсролын Номын ёс сургууль',                subject:'Мэдээллийн технологи' },
        { name:'Г. Отгонтуяа',                  school:'62-р сургууль',                                        subject:'Дүрслэх урлаг' },
        { name:'Гансүх Батгэрэл',               school:'Номын ёс сургууль',                                    subject:'Солонгос хэлний багш' },
        { name:'Б. Дайрий',                     school:'НЕБ-ын Ирээдүй сургууль',                             subject:'Нийгмийн ухааны багш' },
        { name:'Аюушжав овогтой Алтанцэцэг',    school:'НЕБ-ын Эрдмийн Өргөө сургууль',                       subject:'Бага ангийн багш' },
        { name:'Мөнхбаатарын Нандин-Эрдэнэ',    school:'НЕБ-ын 45-р сургууль',                                 subject:'Дизайн технологи' },
        { name:'Дарамбазар Сугармаа',           school:'11-р сургууль',                                        subject:'Биологи' },
        { name:'Пүрвээ Үнэнбат',                school:'"Үр-Эрдэнэ" өдөр өнжүүлэх төв',                       subject:'Бага боловсролын багш' },
        { name:'Балжинням Баттуяа',             school:'Нийслэлийн ерөнхий боловсролын "Ирээдүй" сургууль',    subject:'Бага ангийн багш' },
        { name:'Амар овогтой Цэндбаатар',       school:'Цэлмэг Дижитал интернэйшнл сургууль',                  subject:'График дизайн' },
        { name:'Баатар Армунаа',                school:'Шинэ эхлэл олон улсын хөтөлбөрийн сургууль',           subject:'Математикийн багш' },
        { name:'Дүвчиндорж Оюунчимэг',          school:'—',                                                    subject:'Англи хэл' },
        { name:'Отгоны Мөнхцэцэг',              school:'НЕБ-ын 63 дугаар сургууль',                            subject:'Тусгай хэрэгцээт боловсрол' },
        { name:'Батнямын Даваажаргал',          school:'НЕБ-ийн "Хөгжил" сургууль',                            subject:'Англи хэлний багш' },
        { name:'Дэмбэрэлбаясгалан Дэлгэрмаа',   school:'25-р сургууль',                                        subject:'Түүх, тусгай хэрэгцээт боловсролын багш' },
        { name:'Ганмягмар овогтой Дөлгөөнсувд', school:'ШУТИС',                                                subject:'Мэдээлэл холбооны сүлжээний инжнерчлэл' },
        { name:'Дэлгэрийн Амармэнд',            school:'52-р сургууль',                                        subject:'Мэдээллийн технологийн багш' },
        { name:'Аръяа Болортуяа',               school:'31-р сургууль',                                        subject:'Мэдээлэл технологийн багш' },
        { name:'Б. Долгорсүрэн',                school:'Ирээдүй',                                              subject:'Бага ангийн багш' },
        { name:'Рагчаагийн Бигэрмаа',           school:'ШУТИС, Гадаад хэлний сургууль, Ази судлалын тэнхим',   subject:'Монгол хэл, уран зохиолын багш' },
        { name:'Намшир Ариунзаяа',              school:'11-р сургууль',                                        subject:'Дүрслэх урлаг дизайн технологийн багш' },
        { name:'Наранцэцэг Шинэбаяр',           school:'16-р сургууль',                                        subject:'Дизайн технологи багш' },
    ];

    const AV_COLORS = ['#4a90d9','#3dbe6a','#9a70d9','#d060a0','#d0a030','#e07050','#3dc8b0','#5090e0','#c050c0','#50c080','#d97070','#7090e0'];

    /* Хичээлийн төрөлд харгалзах өнгөний загвар */
    function subjectStyle(s) {
        if (s.includes('МТ') || s.includes('Мэдээл') || s.includes('инжнер'))
            return 'background:#081424;color:#4890d8;border:1px solid #102040';
        if (s.includes('Дизайн') || s.includes('График') || s.includes('Дүрслэх'))
            return 'background:#14082a;color:#9060d0;border:1px solid #201040';
        if (s.includes('Англи'))
            return 'background:#081a1a;color:#30b0a0;border:1px solid #0e2828';
        if (s.includes('Монгол') || s.includes('уран'))
            return 'background:#081a10;color:#30a860;border:1px solid #0e2818';
        if (s.includes('Биологи'))
            return 'background:#081808;color:#40a840;border:1px solid #0e2810';
        if (s.includes('Бага') || s.includes('өмнөх'))
            return 'background:#1a1808;color:#c0a020;border:1px solid #282408';
        if (s.includes('Математик'))
            return 'background:#081428;color:#4080d0;border:1px solid #102038';
        if (s.includes('Түүх') || s.includes('Нийгмийн'))
            return 'background:#181408;color:#b08020;border:1px solid #281e08';
        if (s.includes('Тусгай'))
            return 'background:#201008;color:#d06820;border:1px solid #301808';
        if (s.includes('Солонгос'))
            return 'background:#180818;color:#d060b0;border:1px solid #280828';
        if (s.includes('Газар'))
            return 'background:#081808;color:#40a840;border:1px solid #0e2810';
        return 'background:#101216;color:#607080;border:1px solid #181e24';
    }

    /* Хүснэгтийг рендерлэх — хайлт хийсэн үед шүүнэ */
    function renderTeamTable(query) {
        query = (query || '').toLowerCase().trim();
        const list = query
            ? TEAM.filter(m =>
                m.name.toLowerCase().includes(query) ||
                m.school.toLowerCase().includes(query) ||
                m.subject.toLowerCase().includes(query))
            : TEAM;

        document.getElementById('team-count-lbl').textContent = list.length;
        const tbody = document.getElementById('team-tbody');
        tbody.innerHTML = '';

        if (!list.length) {
            tbody.innerHTML = '<tr><td colspan="4" class="t-no-result">🔍 Тохирох багш олдсонгүй</td></tr>';
            return;
        }

        list.forEach(m => {
            const realIndex = TEAM.indexOf(m);
            const col = AV_COLORS[realIndex % AV_COLORS.length];
            // Овог үсэгийг арилгаж эхний үсэгийг авах
            const init = m.name.replace(/^[А-ЯӨҮа-яөүA-Z]\.\s*/, '').charAt(0).toUpperCase();

            const tr = document.createElement('tr');
            tr.className = 't-row';
            tr.innerHTML = `
                <td><span class="t-num">${String(realIndex + 1).padStart(2, '0')}</span></td>
                <td>
                    <div class="t-name">
                        <span class="t-avatar" style="background:${col}1e;border:1.5px solid ${col}55;color:${col}">${init}</span>
                        ${m.name}
                    </div>
                </td>
                <td><span class="t-school">${m.school}</span></td>
                <td><span class="t-subject" style="${subjectStyle(m.subject)}">${m.subject}</span></td>
            `;
            tbody.appendChild(tr);
        });
    }

    /* Modal нээх / хаах */
    function openTeamModal() {
        renderTeamTable('');
        document.getElementById('team-search-inp').value = '';
        document.getElementById('modal-team').classList.add('open');
        document.body.style.overflow = 'hidden';
        setTimeout(() => document.getElementById('team-search-inp').focus(), 280);
    }
    function closeTeamModal() {
        document.getElementById('modal-team').classList.remove('open');
        document.body.style.overflow = '';
    }
    function openCertModal() {
        document.getElementById('modal-cert').classList.add('open');
        document.body.style.overflow = 'hidden';
    }
    function closeCertModal() {
        document.getElementById('modal-cert').classList.remove('open');
        document.body.style.overflow = '';
    }

    /* ESC товчоор хаах */
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') {
            closeTeamModal();
            closeCertModal();
        }
    });

    /* ══════════════════════════════════════
       ХИЧЭЭЛ АЧААЛАХ — өмнөх кодны логик
    ══════════════════════════════════════ */
    function loadLesson(lessonType, element) {
        const mainContainer = document.getElementById('main-container');
        const mainWrapper   = document.getElementById('main-wrapper');

        document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.remove('active'));
        if (element) element.classList.add('active');

        if (lessonType === 'notes') {
            mainWrapper.style.padding  = '0';
            mainWrapper.style.overflow = 'hidden';
            mainContainer.innerHTML = `
                <div style="height:100vh; width:100%; overflow:hidden;">
                    <iframe src="/notes_lesson.html"
                            style="width:100%; height:100%; border:none;"
                            allow="autoplay"></iframe>
                </div>`;
        }
        else if (lessonType === 'fingering') {
            mainWrapper.style.padding  = '0';
            mainWrapper.style.overflow = 'hidden';
            mainContainer.innerHTML = `
                <div style="height:100vh; width:100%; overflow:hidden;">
                    <iframe src="/fingering_lesson.html"
                            style="width:100%; height:100%; border:none;"
                            allow="autoplay"></iframe>
                </div>`;
        }
        else if (lessonType === 'posture') {
            mainWrapper.style.padding  = '30px';
            mainWrapper.style.overflow = 'auto';
            mainContainer.innerHTML = `
                <div style="height:calc(100vh - 80px); width:100%; border-radius:16px;
                            overflow:hidden; border:1px solid #252840; background:#000;">
                    <iframe src="/posture_coach.html"
                            style="width:100%; height:100%; border:none;"
                            allow="camera; microphone;"></iframe>
                </div>`;
        }
        else if (lessonType === 'breathing') {
            mainWrapper.style.padding  = '30px';
            mainWrapper.style.overflow = 'auto';
            mainContainer.innerHTML = `
                <div style="height:calc(100vh - 80px); width:100%; border-radius:16px;
                            overflow:hidden; border:1px solid #252840; background:#1a1a2e;">
                    <iframe src="/breathing_lesson.html"
                            style="width:100%; height:100%; border:none;"></iframe>
                </div>`;
        }
        else if (lessonType === 'songs') {
            window.location.href = '/Home/EngiinAyalguu';
            return;
        }
        else if (lessonType === 'sound') {
            mainWrapper.style.padding  = '30px';
            mainWrapper.style.overflow = 'auto';
            mainContainer.innerHTML = `
                <div style="height:calc(100vh - 80px); width:100%; border-radius:16px;
                            overflow:hidden; border:1px solid #252840; background:#1a1a2e;">
                    <iframe src="/flute_trainer.html"
                            style="width:100%; height:100%; border:none;"
                            allow="camera; microphone;"></iframe>
                </div>`;
        }
        else {
            mainWrapper.style.padding  = '30px';
            mainWrapper.style.overflow = 'auto';
            mainContainer.innerHTML = `
                <div style="padding:40px; text-align:center; background:var(--s1);
                            border:1px solid var(--bd); border-radius:16px;
                            max-width:900px; margin:0 auto;">
                    <h1 style="color:#fff; font-size:2.5rem;">Хичээл</h1>
                    <p style="color:#9298b8; margin-top:20px; font-size:1.1rem;">
                        Энэхүү хичээлийн агуулга удахгүй орох болно.
                    </p>
                    <div style="margin-top:40px; opacity:0.2; font-size:100px;">📖</div>
                </div>`;
        }
    }
</script>

</body>
</html>
