@{
    Layout = null;
    ViewData["Title"] = "Нүүр хуудас";
}
<!DOCTYPE html>
<html lang="mn">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Бишгүүр Сургалт</title>
    <style>
        :root {
            --bg:  #0c0e14;
            --s1:  #13151d;
            --s2:  #191c28;
            --s3:  #1f2235;
            --bd:  #252840;
            --ac:  #5b9cf6;
            --tx:  #eef0f8;
            --tx2: #9298b8;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body, html {
            background: var(--bg);
            color: var(--tx);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            height: 100vh;
            overflow: hidden;
        }

        .app-wrapper { display: flex; height: 100vh; }

        /* ── Sidebar ── */
        .sidebar {
            width: 260px;
            background: var(--s1);
            border-right: 1px solid var(--bd);
            display: flex;
            flex-direction: column;
            padding: 20px 10px;
            flex-shrink: 0;
        }
        .sidebar-header {
            display: flex; align-items: center; gap: 12px;
            padding: 0 10px 30px;
        }
        .app-logo    { font-size: 28px; }
        .app-title   { font-weight: 700; font-size: 18px; color: var(--tx); }
        .app-subtitle{ font-size: 12px; color: var(--tx2); }

        .sidebar-label {
            font-size: 11px; text-transform: uppercase;
            letter-spacing: 1px; color: var(--tx2);
            margin: 20px 0 10px 10px;
        }

        .nav-menu { display: flex; flex-direction: column; gap: 5px; }

        .nav-btn {
            display: flex; align-items: center; gap: 15px;
            padding: 12px 15px;
            background: transparent; border: none;
            color: var(--tx2); border-radius: 10px;
            cursor: pointer; text-align: left;
            transition: 0.2s; font-size: 15px; width: 100%;
        }
        .nav-btn:hover  { background: var(--s2); color: var(--tx); }
        .nav-btn.active {
            background: var(--s3); color: var(--ac);
            border: 1px solid var(--bd);
        }

        /* ── Үндсэн агуулга ── */
        .main-content {
            flex: 1; overflow-y: auto; padding: 30px;
        }

        .content-card {
            background: var(--s1);
            border: 1px solid var(--bd);
            border-radius: 16px;
            padding: 30px;
            max-width: 900px;
            margin: 0 auto;
        }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--bd); border-radius: 3px; }
    </style>
</head>
<body>

<div class="app-wrapper">

    <!-- ══════════ SIDEBAR ══════════ -->
    <div class="sidebar">
        <div class="sidebar-header">
            <div class="app-logo">🎵</div>
            <div>
                <div class="app-title">Бишгүүр Сургалт</div>
                <div class="app-subtitle">Recorder Learning System</div>
            </div>
        </div>

        <div class="sidebar-label">ХИЧЭЭЛҮҮД</div>
        <div class="nav-menu">
            <button class="nav-btn" onclick="loadLesson('notes', this)">
                <span>🎵</span> Нот сурах
            </button>
            <button class="nav-btn" onclick="loadLesson('fingering', this)">
                <span>🤚</span> Хурууны байрлал
            </button>
            <button class="nav-btn" onclick="loadLesson('breathing', this)">
                <span>💨</span> Амьсгалын техник
            </button>
            <button class="nav-btn" onclick="loadLesson('posture', this)">
                <span>🧍</span> Биеийн галбир
            </button>
        </div>

        <div class="sidebar-label">ХЯНАЛТ</div>
        <div class="nav-menu">
            <button class="nav-btn" onclick="loadLesson('sound', this)">
                <span>🔊</span> Дуу авианы хяналт
            </button>
            <button class="nav-btn" onclick="loadLesson('songs', this)">
                <span>🎸</span> Энгийн аянууд
            </button>
        </div>
    </div>

    <!-- ══════════ ҮНДСЭН АГУУЛГА ══════════ -->
    <div class="main-content" id="main-wrapper">
        <div id="main-container">

            <!-- ══════ НҮҮР ХУУДАС — БИШГҮҮРИЙН ТҮҮХ ══════ -->
            <div style="display:flex; flex-direction:column; gap:20px; max-width:860px; margin:0 auto;">

                <!-- Hero хэсэг -->
                <div style="background: linear-gradient(135deg, #1a1d2e 0%, #0f111a 100%);
                            border: 1px solid var(--bd); border-radius: 18px;
                            padding: 40px 40px 35px; position: relative; overflow: hidden;">
                    <div style="position:absolute; top:-30px; right:-20px;
                                font-size:160px; opacity:0.06; line-height:1;">🎵</div>
                    <div style="display:flex; align-items:center; gap:15px; margin-bottom:18px;">
                        <div style="width:5px; height:50px; background:var(--ac); border-radius:3px;"></div>
                        <div>
                            <div style="font-size:11px; letter-spacing:2px;
                                        color:var(--tx2); text-transform:uppercase;">
                                Тавтай морилно уу
                            </div>
                            <h1 style="font-size:28px; color:var(--tx); margin-top:4px;">
                                Бишгүүр хөгжмийн түүх
                            </h1>
                        </div>
                    </div>
                    <p style="color:var(--tx2); font-size:15px; line-height:1.9; max-width:640px;">
                        Бишгүүр — дэлхийн хамгийн эртний хөгжмийн зэмсгүүдийн нэг бөгөөд
                        хүний соёл иргэншлийн хамт хөгжиж ирсэн гайхамшигт түүхтэй.
                        Энэхүү сургалтын систем нь таныг бишгүүрийн урлагт суралцахад
                        туслах зорилготой.
                    </p>
                </div>

                <!-- Цаг хугацааны шугам -->
                <div style="background:var(--s1); border:1px solid var(--bd);
                            border-radius:18px; padding:30px 35px;">
                    <div style="font-size:11px; letter-spacing:2px; color:var(--tx2);
                                text-transform:uppercase; margin-bottom:25px;">
                        📅 Түүхэн цаг хугацааны шугам
                    </div>

                    <div style="display:flex; flex-direction:column; gap:0;">

                        <div style="display:flex; gap:20px; align-items:stretch;">
                            <div style="display:flex; flex-direction:column; align-items:center; min-width:60px;">
                                <div style="width:44px; height:44px; border-radius:50%;
                                            background:#1a2a4a; border:2px solid var(--ac);
                                            display:flex; align-items:center; justify-content:center;
                                            font-size:18px; flex-shrink:0;">🦴</div>
                                <div style="width:2px; flex:1; background:var(--bd);
                                            margin:6px 0; min-height:30px;"></div>
                            </div>
                            <div style="padding-bottom:28px;">
                                <div style="font-size:12px; color:var(--ac); font-weight:600; margin-bottom:4px;">~43,000 жилийн өмнө</div>
                                <div style="font-size:15px; font-weight:700; color:var(--tx); margin-bottom:6px;">Хамгийн эртний бишгүүр</div>
                                <div style="font-size:14px; color:var(--tx2); line-height:1.7;">Германы Хоэле Фелс агуйгаас шувуу болон мамонтын яснаас хийсэн бишгүүр олдсон нь дэлхийд мэдэгдэж буй хамгийн эртний хөгжмийн зэмсэг болсон байна.</div>
                            </div>
                        </div>

                        <div style="display:flex; gap:20px; align-items:stretch;">
                            <div style="display:flex; flex-direction:column; align-items:center; min-width:60px;">
                                <div style="width:44px; height:44px; border-radius:50%;
                                            background:#1a3a1a; border:2px solid #27ae60;
                                            display:flex; align-items:center; justify-content:center;
                                            font-size:18px; flex-shrink:0;">🏛️</div>
                                <div style="width:2px; flex:1; background:var(--bd); margin:6px 0; min-height:30px;"></div>
                            </div>
                            <div style="padding-bottom:28px;">
                                <div style="font-size:12px; color:#27ae60; font-weight:600; margin-bottom:4px;">Эртний Грек, Ром (МЭӨ 500)</div>
                                <div style="font-size:15px; font-weight:700; color:var(--tx); margin-bottom:6px;">Соёлын бэлгэдэл болсон үе</div>
                                <div style="font-size:14px; color:var(--tx2); line-height:1.7;">Эртний Грек, Ром, Египетийн соёл иргэншилд лимбэ хэлбэрийн хөгжим тахил өргөх, баяр наадам болон цэргийн ёслолд өргөн хэрэглэгдэж байсан.</div>
                            </div>
                        </div>

                        <div style="display:flex; gap:20px; align-items:stretch;">
                            <div style="display:flex; flex-direction:column; align-items:center; min-width:60px;">
                                <div style="width:44px; height:44px; border-radius:50%;
                                            background:#2a1a3a; border:2px solid #8e44ad;
                                            display:flex; align-items:center; justify-content:center;
                                            font-size:18px; flex-shrink:0;">👑</div>
                                <div style="width:2px; flex:1; background:var(--bd); margin:6px 0; min-height:30px;"></div>
                            </div>
                            <div style="padding-bottom:28px;">
                                <div style="font-size:12px; color:#8e44ad; font-weight:600; margin-bottom:4px;">Дундад зуун (1000–1400)</div>
                                <div style="font-size:15px; font-weight:700; color:var(--tx); margin-bottom:6px;">Европт өргөн тархсан үе</div>
                                <div style="font-size:14px; color:var(--tx2); line-height:1.7;">Дундад зууны Европт "recorder" нэртэй модон бишгүүр ордны хөгжимчид, тавцангийн жүжигчдийн дунд нэр хүндтэй хөгжмийн зэмсэг болж хөгжсөн.</div>
                            </div>
                        </div>

                        <div style="display:flex; gap:20px; align-items:stretch;">
                            <div style="display:flex; flex-direction:column; align-items:center; min-width:60px;">
                                <div style="width:44px; height:44px; border-radius:50%;
                                            background:#2a2a0a; border:2px solid #f1c40f;
                                            display:flex; align-items:center; justify-content:center;
                                            font-size:18px; flex-shrink:0;">🎼</div>
                                <div style="width:2px; flex:1; background:var(--bd); margin:6px 0; min-height:30px;"></div>
                            </div>
                            <div style="padding-bottom:28px;">
                                <div style="font-size:12px; color:#f1c40f; font-weight:600; margin-bottom:4px;">Барокко үе (1600–1750)</div>
                                <div style="font-size:15px; font-weight:700; color:var(--tx); margin-bottom:6px;">Алтан үе — Бах, Вивалди</div>
                                <div style="font-size:14px; color:var(--tx2); line-height:1.7;">Иоганн Себастьян Бах, Антонио Вивалди зэрэг агуу хөгжимчид бишгүүрт зориулсан олон бүтээл туурвисан нь энэ зэмсгийн хамгийн цэцэглэлтийн үе болсон.</div>
                            </div>
                        </div>

                        <div style="display:flex; gap:20px; align-items:stretch;">
                            <div style="display:flex; flex-direction:column; align-items:center; min-width:60px;">
                                <div style="width:44px; height:44px; border-radius:50%;
                                            background:#1a2a3a; border:2px solid var(--ac);
                                            display:flex; align-items:center; justify-content:center;
                                            font-size:18px; flex-shrink:0;">🌍</div>
                            </div>
                            <div style="padding-bottom:10px;">
                                <div style="font-size:12px; color:var(--ac); font-weight:600; margin-bottom:4px;">Орчин үе (1900 — өнөөг хүртэл)</div>
                                <div style="font-size:15px; font-weight:700; color:var(--tx); margin-bottom:6px;">Дэлхийн сургуулиудад нэвтэрсэн үе</div>
                                <div style="font-size:14px; color:var(--tx2); line-height:1.7;">XX зуунаас эхлэн бишгүүр дэлхийн 100 гаруй улсын ерөнхий боловсролын сургуулиудад заавал заах хөгжмийн зэмсэг болж тогтсон. Японд 30 сая, Германд 15 сая, Австралид 10 сая гаруй хүн тоглодог.</div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Статистик карт -->
                <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:15px;">
                    <div style="background:var(--s1); border:1px solid var(--bd); border-radius:14px; padding:22px; text-align:center;">
                        <div style="font-size:36px; font-weight:900; color:var(--ac); line-height:1;">43,000+</div>
                        <div style="font-size:13px; color:var(--tx2); margin-top:6px;">жилийн түүхтэй</div>
                    </div>
                    <div style="background:var(--s1); border:1px solid var(--bd); border-radius:14px; padding:22px; text-align:center;">
                        <div style="font-size:36px; font-weight:900; color:#27ae60; line-height:1;">100+</div>
                        <div style="font-size:13px; color:var(--tx2); margin-top:6px;">улсад заагддаг</div>
                    </div>
                    <div style="background:var(--s1); border:1px solid var(--bd); border-radius:14px; padding:22px; text-align:center;">
                        <div style="font-size:36px; font-weight:900; color:#f1c40f; line-height:1;">50M+</div>
                        <div style="font-size:13px; color:var(--tx2); margin-top:6px;">тоглогч дэлхий даяар</div>
                    </div>
                </div>

                <!-- Яагаад бишгүүр сурах вэ -->
                <div style="background:var(--s1); border:1px solid var(--bd); border-radius:18px; padding:30px 35px; margin-bottom:30px;">
                    <div style="font-size:11px; letter-spacing:2px; color:var(--tx2); text-transform:uppercase; margin-bottom:20px;">🎯 Яагаад бишгүүр сурах вэ?</div>
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px;">
                        <div style="display:flex; gap:14px; align-items:flex-start; background:var(--s2); border-radius:12px; padding:16px;">
                            <div style="font-size:24px;">🧠</div>
                            <div>
                                <div style="font-size:14px; font-weight:700; color:var(--tx); margin-bottom:4px;">Тархины хөгжил</div>
                                <div style="font-size:13px; color:var(--tx2); line-height:1.6;">Хөгжим тоглох нь тархины хоёр хагасыг зэрэг ажиллуулж, санах ой болон анхаарлыг сайжруулдаг.</div>
                            </div>
                        </div>
                        <div style="display:flex; gap:14px; align-items:flex-start; background:var(--s2); border-radius:12px; padding:16px;">
                            <div style="font-size:24px;">💨</div>
                            <div>
                                <div style="font-size:14px; font-weight:700; color:var(--tx); margin-bottom:4px;">Амьсгалын чадвар</div>
                                <div style="font-size:13px; color:var(--tx2); line-height:1.6;">Бишгүүр үлээх нь уушгины багтаамжийг нэмэгдүүлж, амьсгалын зөв техникийг сургадаг.</div>
                            </div>
                        </div>
                        <div style="display:flex; gap:14px; align-items:flex-start; background:var(--s2); border-radius:12px; padding:16px;">
                            <div style="font-size:24px;">👐</div>
                            <div>
                                <div style="font-size:14px; font-weight:700; color:var(--tx); margin-bottom:4px;">Хурууны нарийн моторик</div>
                                <div style="font-size:13px; color:var(--tx2); line-height:1.6;">Хурууны нарийн хөдөлгөөн нь гарын булчин болон мэдрэлийг хөгжүүлдэг.</div>
                            </div>
                        </div>
                        <div style="display:flex; gap:14px; align-items:flex-start; background:var(--s2); border-radius:12px; padding:16px;">
                            <div style="font-size:24px;">🎒</div>
                            <div>
                                <div style="font-size:14px; font-weight:700; color:var(--tx); margin-bottom:4px;">Хялбар эхлэлийн зэмсэг</div>
                                <div style="font-size:13px; color:var(--tx2); line-height:1.6;">Бусад хөгжмийн зэмсгийн суурь болдог тул хөгжмийн боловсролд хамгийн тохиромжтой эхлэл.</div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
            <!-- ══════ НҮҮР ХУУДАС ТӨГСГӨЛ ══════ -->

        </div>
    </div>

</div>

<script>
    function loadLesson(lessonType, element) {
        const mainContainer = document.getElementById('main-container');
        const mainWrapper   = document.getElementById('main-wrapper');

        document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.remove('active'));
        if (element) element.classList.add('active');

        if (lessonType === 'notes') {
            mainWrapper.style.padding  = '0';
            mainWrapper.style.overflow = 'hidden';
            mainContainer.innerHTML = `
                <div style="height:100vh; width:100%; overflow:hidden;">
                    <iframe src="/notes_lesson.html"
                            style="width:100%; height:100%; border:none;"
                            allow="autoplay"></iframe>
                </div>`;
        }
        // ✅ ШИНЭ: Хурууны байрлал — fingering_lesson.html
        else if (lessonType === 'fingering') {
            mainWrapper.style.padding  = '0';
            mainWrapper.style.overflow = 'hidden';
            mainContainer.innerHTML = `
                <div style="height:100vh; width:100%; overflow:hidden;">
                    <iframe src="/fingering_lesson.html"
                            style="width:100%; height:100%; border:none;"
                            allow="autoplay"></iframe>
                </div>`;
        }
        else if (lessonType === 'posture') {
            mainWrapper.style.padding  = '30px';
            mainWrapper.style.overflow = 'auto';
            mainContainer.innerHTML = `
                <div style="height:calc(100vh - 80px); width:100%; border-radius:16px;
                            overflow:hidden; border:1px solid #252840; background:#000;">
                    <iframe src="/posture_coach.html"
                            style="width:100%; height:100%; border:none;"
                            allow="camera; microphone;"></iframe>
                </div>`;
        }
        else if (lessonType === 'breathing') {
            mainWrapper.style.padding  = '30px';
            mainWrapper.style.overflow = 'auto';
            mainContainer.innerHTML = `
                <div style="height:calc(100vh - 80px); width:100%; border-radius:16px;
                            overflow:hidden; border:1px solid #252840; background:#1a1a2e;">
                    <iframe src="/breathing_lesson.html"
                            style="width:100%; height:100%; border:none;"></iframe>
                </div>`;
        }
        else if (lessonType === 'songs') {
            window.location.href = '/Home/EngiinAyalguu';
            return;
        }
        else if (lessonType === 'sound') {
            mainWrapper.style.padding  = '30px';
            mainWrapper.style.overflow = 'auto';
            mainContainer.innerHTML = `
                <div style="height:calc(100vh - 80px); width:100%; border-radius:16px;
                            overflow:hidden; border:1px solid #252840; background:#1a1a2e;">
                    <iframe src="/flute_trainer.html"
                            style="width:100%; height:100%; border:none;"
                            allow="camera; microphone;"></iframe>
                </div>`;
        }
        // ✅ Хурууны байрлал — fingering_lesson.html
        else if (lessonType === 'fingering') {
            mainWrapper.style.padding  = '0';
            mainWrapper.style.overflow = 'hidden';
            mainContainer.innerHTML = `
                <div style="height:100vh; width:100%; overflow:hidden;">
                    <iframe src="/fingering_lesson.html"
                            style="width:100%; height:100%; border:none;"
                            allow="autoplay"></iframe>
                </div>`;
        }
        else {
            mainWrapper.style.padding  = '30px';
            mainWrapper.style.overflow = 'auto';
            mainContainer.innerHTML = `
                <div style="padding:40px; text-align:center; background:var(--s1);
                            border:1px solid var(--bd); border-radius:16px;
                            max-width:900px; margin:0 auto;">
                    <h1 style="color:#fff; font-size:2.5rem;">Хичээл</h1>
                    <p style="color:#9298b8; margin-top:20px; font-size:1.1rem;">
                        Энэхүү хичээлийн агуулга удахгүй орох болно.
                    </p>
                    <div style="margin-top:40px; opacity:0.2; font-size:100px;">📖</div>
                </div>`;
        }
    }
</script>

</body>
</html>
