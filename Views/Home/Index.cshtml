        </div>
        <div class="lm-body">
            <div class="cert-card">
                <div class="cert-seal">🏅</div>
                <div class="cert-tag">📌 Бүтээгч баг</div>
                <div class="cert-school-name">БАГАТЭНГЭР</div>
                <div class="cert-school-full">Олон улсын сургууль</div>

                <div class="cert-divider"></div>

                <div class="cert-body">
